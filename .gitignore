# =============================================================================
# TwachaRakshak AI — .gitignore
# Excludes datasets, training artefacts, secrets, and common build/tool output
# =============================================================================

# ---------------------------------------------------------------------------
# Datasets & raw data
# ---------------------------------------------------------------------------
training/data/
data/
datasets/
*.csv
*.tsv
*.parquet
*.feather
*.h5
*.hdf5
*.json.gz
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.7z

# ---------------------------------------------------------------------------
# Model checkpoints & training artefacts
# ---------------------------------------------------------------------------
backend/models/
training/checkpoints/
training/runs/
training/outputs/
*.pth
*.pt
*.ckpt
*.safetensors
*.pkl
*.joblib
*.bin
*.onnx
*.tflite
*.pb
*.engine

# MLflow / Weights & Biases artefacts
mlruns/
mlartifacts/
wandb/

# ---------------------------------------------------------------------------
# Secrets & credentials
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
service_account*.json
*_secret*
*_credentials*
config/local*.py
config/production*.py

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.eggs/
*.egg-info/
dist/
build/
*.egg
*.whl
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log
*.pot
*.mo

# Jupyter Notebooks — track notebooks, ignore checkpoint snapshots
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Node / React / Vite
# ---------------------------------------------------------------------------
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
.npm
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# ---------------------------------------------------------------------------
# Temporary / scratch files
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej

# ---------------------------------------------------------------------------
# Docs build output
# ---------------------------------------------------------------------------
docs/_build/
site/
